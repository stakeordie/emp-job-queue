NAMESPACE=GPU-MACHINE

[default]
ENABLE_SIMULATION=false
ENABLE_COMFYUI=false
ENABLE_NGINX=false
ENABLE_A1111=false
ENABLE_OLLAMA=false
EXPOSE_PORTS=false
LOG_LEVEL=info
HAS_GPU=false

[sim]
ID=sim-machine
ENABLE_SIMULATION=true
HEALTH_PORT=9090
SERVICES=simulation
EXPOSE_PORTS=true

[local]
ID=local-dev-machine
ENABLE_SIMULATION=true
ENABLE_COMFYUI=true
SERVICES=simulation,comfyui
EXPOSE_PORTS=true

[remote]
ID=local-dev-machine-rem-comfy
ENABLE_COMFYUI=false

[test]
ID=test-machine
ENABLE_SIMULATION=true
ENABLE_COMFYUI=true
HAS_GPU=true

[production]
ID=production-machine
ENABLE_SIMULATION=true
ENABLE_COMFYUI=true
SERVICES=simulation,comfyui
HAS_GPU=true

LOG_LEVEL=info
# ComfyUI Connector Settings (connects to local ComfyUI by default)
WORKER_COMFYUI_TIMEOUT_SECONDS=300
MAX_CONCURRENT_JOBS=1