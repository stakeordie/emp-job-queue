# Monitor component configurations
NAMESPACE=MONITOR

[default]
HOST=localhost
PORT=3333
LOG_LEVEL=info
RETRY=REFRESH
RETRY_ATTEMPTS=5 
CONNECTION=[{"WS_URL":"localhost:3331","AUTH_KEY":"${API_AUTH_KEY}","NAME":"local"},{"WS_URL":"emp-job-queue-production.up.railway.app","AUTH_KEY":"${API_AUTH_KEY}","NAME":"production"}]

[local]
LOG_LEVEL=debug

[production]
RETRY=AUTO
RETRY_ATTEMPTS=25
RETRY_DELAY=1000
CONNECTION={"WS_URL":"emp-job-queue-production.up.railway.app","AUTH_KEY":"${API_AUTH_KEY}","NAME":"production"}