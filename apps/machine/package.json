{
  "name": "@emp/unified-machine",
  "version": "1.0.0",
  "description": "Unified machine for EmProps AI workload processing - supports GPU, API, and Hybrid configurations",
  "main": "src/machine-manager.js",
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "start": "node src/machine-manager.js",
    "dev": "NODE_ENV=development node src/machine-manager.js",
    "build": "./build-all.sh all",
    "build:base": "./build-all.sh base",
    "build:gpu": "./build-all.sh gpu",
    "build:api": "./build-all.sh api",
    "build:hybrid": "./build-all.sh hybrid",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "clean": "rm -rf node_modules logs/* data/* shared/models/* ComfyUI/output/*",
    "ecosystem:generate": "node src/config/ecosystem-generator.js",
    "ecosystem:gpu": "MACHINE_TYPE=gpu MACHINE_NUM_GPUS=1 MACHINE_ENABLE_COMFYUI=true node src/config/ecosystem-generator.js",
    "ecosystem:api": "MACHINE_TYPE=api MACHINE_ENABLE_API=true node src/config/ecosystem-generator.js",
    "ecosystem:hybrid": "MACHINE_TYPE=hybrid MACHINE_NUM_GPUS=1 MACHINE_ENABLE_COMFYUI=true MACHINE_ENABLE_API=true node src/config/ecosystem-generator.js",
    "pm2:start": "pm2 start pm2-ecosystem.config.cjs",
    "pm2:stop": "pm2 stop all",
    "pm2:restart": "pm2 restart all",
    "pm2:delete": "pm2 delete all",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "health": "curl -f http://localhost:9090/health",
    "status": "curl http://localhost:9090/status",
    "docker:build": "./scripts/build-with-version.sh",
    "docker:build:version": "./scripts/build-with-version.sh",
    "docker:build:push": "./scripts/build-with-version.sh latest emprops unified-machine --push"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.27.0",
    "@emp/core": "workspace:*",
    "@emp/service-config": "workspace:*",
    "@emp/custom-nodes": "workspace:*",
    "axios": "^1.6.8",
    "dotenv": "^16.4.5",
    "execa": "^8.0.1",
    "express": "^4.21.2",
    "form-data": "^4.0.0",
    "fs-extra": "^11.2.0",
    "ioredis": "^5.6.1",
    "joi": "^17.12.2",
    "mime-types": "^2.1.35",
    "node-fetch": "^3.3.2",
    "p-queue": "^8.0.1",
    "p-retry": "^6.2.0",
    "tar": "^7.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "eslint": "^8.57.0",
    "nodemon": "^3.1.0",
    "vitest": "^3.2.4",
    "@vitest/ui": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "gpu",
    "api",
    "hybrid",
    "ai",
    "machine-learning",
    "distributed-computing",
    "comfyui",
    "openai",
    "replicate",
    "runpod",
    "redis",
    "pm2",
    "worker",
    "orchestration"
  ],
  "author": "EmProps Infrastructure Team",
  "license": "MIT",
  "config": {
    "machineTypes": ["gpu", "api", "hybrid"],
    "supportedPlatforms": ["linux/amd64", "linux/arm64"],
    "defaultPorts": {
      "health": 9090,
      "comfyui": 8188,
      "simulation": 8080,
      "metrics": 9091
    }
  }
}
