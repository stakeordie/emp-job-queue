# API Machine Environment Configuration

# Service Configuration
NODE_ENV=development
MACHINE_ID=api-machine-local
PORT=3000
HOST=0.0.0.0
HEALTH_PORT=9090

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Worker Configuration
WORKER_COUNT=2
WORKER_SERVICES=simulation,openai
WORKER_POLL_INTERVAL=1000

# Simulation Service
ENABLE_SIMULATION=true
SIMULATION_PORT=8000
SIMULATION_DELAY=2000

# OpenAI Service (Phase 1)
ENABLE_OPENAI=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=60000
OPENAI_RETRIES=3

# Error Handling
MAX_JOB_RETRIES=3
RETRY_DELAY=5000
JOB_TIMEOUT_MINUTES=30

# Logging
LOG_LEVEL=info
LOG_FORMAT=json